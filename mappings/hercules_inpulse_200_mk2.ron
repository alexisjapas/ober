// Hercules DJControl Inpulse 200 MK2 mapping.
//
// Primary source: the Mixxx mapping of the Inpulse 200 (mixxxdj/mixxx repo,
// res/controllers/Hercules_DJControl_Inpulse_200.midi.xml + its JS script) —
// the MK2 is reputed compatible. EVERY CODE REMAINS TO BE VALIDATED ON THE
// HARDWARE with `cargo run -p midi --bin midi-probe` (TESTING.md checklist, M3).
//
// Controller particularities (noted in the Mixxx reference):
// - the Shift layer is handled BY THE HARDWARE: shifted buttons are emitted on
//   channels 4/5 (0x94/0x95), shifted jogs on 0xB4/0xB5 — the format's `shift`
//   flag stays available for other controllers;
// - only 2 EQ bands (low CC 0x02, high CC 0x04) — no mid band;
// - headphone volume and cue/master mix are ANALOG (no MIDI): they stay on the
//   keyboard in ober;
// - 14-bit pitch (MSB 0x08, LSB 0x28) — only the MSB is used for now;
// - jogs: 0x09 = rotation without touch (bend), 0x0A = rotation with touch
//   (scratch), note 0x08 = capacitive touch; ±1 in two's complement;
// - LEDs become drivable after the "full MIDI" init message (0xB0 0x7F 0x7F);
//   feedback (play/cue/vinyl…): milestone M5.

Mapping(
    name: "Hercules DJControl Inpulse 200 MK2",
    device_match: ["DJControl Inpulse 200 MK2", "DJControl"],

    // Enable LED control (reference: Mixxx's DJCi200.init).
    init: [
        (0xB0, 0x7F, 0x7F),
    ],

    controls: [
        // --- Transport (deck A = channel 1, deck B = channel 2) ---
        (input: NoteOn(ch: 1, note: 0x07), action: Play(deck: A), mode: Toggle),
        (input: NoteOn(ch: 2, note: 0x07), action: Play(deck: B), mode: Toggle),
        (input: NoteOn(ch: 1, note: 0x06), action: Cue(deck: A), mode: Momentary),
        (input: NoteOn(ch: 2, note: 0x06), action: Cue(deck: B), mode: Momentary),

        // --- Headphone pre-listen (PFL) ---
        (input: NoteOn(ch: 1, note: 0x0C), action: HeadphoneCue(deck: A), mode: Toggle),
        (input: NoteOn(ch: 2, note: 0x0C), action: HeadphoneCue(deck: B), mode: Toggle),

        // --- Library (BROWSER encoder + Load buttons) ---
        // Library open: Load loads the selected track onto the deck;
        // closed: Load opens the library.
        (input: NoteOn(ch: 1, note: 0x0D), action: Load(deck: A), mode: Momentary),
        (input: NoteOn(ch: 2, note: 0x0D), action: Load(deck: B), mode: Momentary),
        (input: CC(ch: 0, cc: 0x01), action: LibraryScroll, mode: Relative(encoding: TwosComplement)),
        // Shift + BROWSER encoder: the folder pane (hardware shift = +4 on
        // the channel, like the jogs) — to confirm with midi-probe.
        (input: CC(ch: 4, cc: 0x01), action: LibraryFolderScroll, mode: Relative(encoding: TwosComplement)),
        (input: NoteOn(ch: 0, note: 0x00), action: LibraryEnter, mode: Momentary),

        // --- Mixing ---
        (input: CC(ch: 0, cc: 0x00), action: CrossFader, mode: Absolute()),
        (input: CC(ch: 1, cc: 0x00), action: Volume(deck: A), mode: Absolute()),
        (input: CC(ch: 2, cc: 0x00), action: Volume(deck: B), mode: Absolute()),

        // --- EQ (2 bands on this controller) ---
        (input: CC(ch: 1, cc: 0x02), action: EqLow(deck: A), mode: Absolute(curve: DbLinear(-26, 6))),
        (input: CC(ch: 1, cc: 0x04), action: EqHigh(deck: A), mode: Absolute(curve: DbLinear(-26, 6))),
        (input: CC(ch: 2, cc: 0x02), action: EqLow(deck: B), mode: Absolute(curve: DbLinear(-26, 6))),
        (input: CC(ch: 2, cc: 0x04), action: EqHigh(deck: B), mode: Absolute(curve: DbLinear(-26, 6))),

        // --- Pitch (±8 % engine-side; direction to validate on the hardware) ---
        (input: CC(ch: 1, cc: 0x08), action: Pitch(deck: A), mode: Absolute()),
        (input: CC(ch: 2, cc: 0x08), action: Pitch(deck: B), mode: Absolute()),

        // --- Jogs (translated since M3, consumed by the M4 scratch model) ---
        (input: NoteOn(ch: 1, note: 0x08), action: JogTouch(deck: A), mode: Gate),
        (input: NoteOn(ch: 2, note: 0x08), action: JogTouch(deck: B), mode: Gate),
        (input: CC(ch: 1, cc: 0x09), action: JogBend(deck: A), mode: Relative(encoding: TwosComplement)),
        (input: CC(ch: 2, cc: 0x09), action: JogBend(deck: B), mode: Relative(encoding: TwosComplement)),
        (input: CC(ch: 1, cc: 0x0A), action: JogTick(deck: A), mode: Relative(encoding: TwosComplement)),
        (input: CC(ch: 2, cc: 0x0A), action: JogTick(deck: B), mode: Relative(encoding: TwosComplement)),
    ],

    // LED feedback (codes lifted from Mixxx — same notes as the buttons).
    // No known MIDI VU on this controller: the format's VuMaster and VuDeck
    // states stay available for other hardware.
    feedback: [
        (state: Playing(deck: A), output: NoteOn(ch: 1, note: 0x07)),
        (state: Playing(deck: B), output: NoteOn(ch: 2, note: 0x07)),
        (state: CueSet(deck: A), output: NoteOn(ch: 1, note: 0x06)),
        (state: CueSet(deck: B), output: NoteOn(ch: 2, note: 0x06)),
        (state: HeadphoneCue(deck: A), output: NoteOn(ch: 1, note: 0x0C)),
        (state: HeadphoneCue(deck: B), output: NoteOn(ch: 2, note: 0x0C)),
        (state: EndOfTrack(deck: A), output: NoteOn(ch: 1, note: 0x1C)),
        (state: EndOfTrack(deck: B), output: NoteOn(ch: 2, note: 0x1C)),
    ],

    jog: (
        ticks_per_rev: 720,     // to validate with midi-probe on the hardware
        touch_scratch: true,
        bend_sensitivity: 0.3,
        release_ramp_ms: 100,
    ),
)
