// Optional ober configuration: copy to `ober.config.ron` next to the binary
// (or in the launch directory) and adapt.
//
// Without a config file: automatic detection of a device whose name contains
// "DJControl" (4-channel master+headphone stream if it supports it), otherwise
// the system default device in stereo.
Config(
    // Case-insensitive substring of the output device name.
    device_match: Some("DJControl"),
    // Buffer size in frames (256 ≈ 5.3 ms @ 48 kHz, ≈ 5.8 ms @ 44.1 kHz).
    // Every matching device alias and every candidate rate is tried at this
    // exact size first; only then does the engine fall back to clamped or
    // default sizes (cf. docs/latency.md).
    buffer_frames: Some(256),
    // Forces a sample rate in Hz. Unset (None): automatic — 48 kHz
    // preferred, 44.1 kHz when it lets the device honor `buffer_frames`
    // (the DJControl Inpulse 200 Mk2 is natively 44.1 kHz-only: at 48 kHz
    // the ALSA resampler imposes a ~23 ms buffer).
    sample_rate: None,
    // Master output: `Controller` (name-matched card, 4-channel
    // master + headphones) or `System` (default PC device, stereo).
    // Switchable at runtime from the F12 panel, which persists the choice
    // here (hand-written comments are then lost).
    output: Controller,
)
